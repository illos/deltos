{
  "name": "deltos",
  "version": "0.0.0",
  "private": true,
  "description": "A private, multi-surface notes framework — one substrate, many surfaces.",
  "packageManager": "pnpm@11.5.3",
  "engines": {
    "node": ">=22"
  },
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel run dev",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:migrate:local": "pnpm --filter @deltos/worker db:migrate:local"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0"
  }
}
