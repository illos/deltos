{
  "name": "@deltos/worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "deltos backend — Cloudflare Worker + Hono + D1. The substrate's server edge; every route passes through the can() chokepoint.",
  "scripts": {
    "dev": "wrangler dev --port 8787",
    "build": "tsc -p tsconfig.json --noEmit && wrangler deploy --dry-run --outdir dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply deltos --local",
    "db:migrate:remote": "wrangler d1 migrations apply deltos --remote"
  },
  "dependencies": {
    "@deltos/shared": "workspace:*",
    "@noble/ed25519": "^3.1.0",
    "@noble/hashes": "^2.2.0",
    "aws4fetch": "^1.0.20",
    "hono": "^4.6.14",
    "unpdf": "^1.6.2",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241218.0",
    "@deltos/client": "workspace:*",
    "@types/better-sqlite3": "^7.6.12",
    "better-sqlite3": "^11.10.0",
    "fake-indexeddb": "^6.0.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "wrangler": "^4.0.0"
  }
}
