{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "deltos",
  // Prod lives in the Blackgate Studio Cloudflare account (user-confirmed 2026-06-16).
  "account_id": "462b5ee1e395c11b8523d6c38de0577a",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-01",
  "observability": {
    "enabled": true,
  },
  // Workers AI (custom-keyboard spec §6 — voice-to-text). Binding `AI` powers POST /api/transcribe
  // (Whisper @cf/openai/whisper-large-v3-turbo); reused later by the advanced-LLM spellcheck add-on.
  // NOTE: Workers AI has no local inference — `wrangler dev` can't run it; use a deploy or
  // `wrangler dev --remote`.
  "ai": {
    "binding": "AI",
  },
  // Cloudflare Workers Images (file-notes spec §4 — `compute` host capability). In-Worker transforms of
  // PRIVATE R2 image bytes: upload-time dual-WebP pre-bake (thumb 256² cover + view ≤2048px scale-down)
  // and download-time JPEG transcode. NO local impl — `wrangler dev` can't run it; use a deploy or
  // `wrangler dev --remote` (same constraint as the `AI` binding above).
  "images": {
    "binding": "IMAGES",
  },
  // Append-only SECURITY AUDIT log (ROAD-0005 P3). A Workers Analytics Engine dataset — `writeDataPoint()`
  // is append-only by construction (no update/delete API), so it's the tamper-resistant who/what/where
  // trail of every access decision + credential-lifecycle event. SEPARATE binding from `DB` on purpose:
  // the data layer never receives this handle, so a compromised data path cannot wipe the log (separation
  // of duties; P5 red-team scoreboard). No provisioning step — the dataset is created on first write.
  // Query via the AE SQL API (`SELECT ... FROM deltos_audit`); no local emulation (deploy to exercise).
  "analytics_engine_datasets": [
    {
      "binding": "AUDIT",
      "dataset": "deltos_audit",
    },
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "deltos",
      // Prod D1 in the Blackgate Studio account (created 2026-06-16). Local dev uses miniflare's
      // own SQLite file and ignores this id.
      "database_id": "0892afd3-67a2-410b-8131-6b4fa64269d8",
      "migrations_dir": "migrations",
    },
  ],
  // Workers PAID (user upgrade 2026-06-18): raise the CPU ceiling so full-strength Argon2id
  // (m=19456,t=2,p=1) signup/login/reset no longer trips the free-plan ~10ms cap (CF 1102
  // exceededCpu). Full secSys-load-bearing params stay — Paid funds the cost.
  "limits": {
    "cpu_ms": 30000,
  },
  "vars": {
    // F13 fail-CLOSED tripwire: prod refuses the dev-only unverified principal.
    "ENVIRONMENT": "production",
    // F8/PROP-4: the auth audience bound into every signed payload. MUST equal the served hostname
    // (= WebAuthn RP ID = client location.hostname). CANONICAL domain = the custom domain
    // deltos.blackgate.studio (user switch 2026-06-16); the workers.dev origin's auth now 401s by
    // design (passkeys are RP-bound per domain → enroll fresh on the canonical domain).
    "AUTH_AUDIENCE": "deltos.blackgate.studio",
    // Direct-to-R2 large-file upload (direct-r2-upload.md §3.1/§5.1). The S3-API endpoint host the presign
    // route targets = `https://<account_id>.r2.cloudflarestorage.com` where <account_id> is the `account_id`
    // above. NON-SECRET (it's just a host); the credentials are the two secrets below, NOT here.
    "R2_S3_ENDPOINT": "https://462b5ee1e395c11b8523d6c38de0577a.r2.cloudflarestorage.com",
  },
  // Direct-to-R2 upload SECRETS (direct-r2-upload.md §5.1) — the R2 S3-API token that POST /api/plugin/blob/presign
  // signs with. Provisioned ONCE by Jim, NEVER hardcoded here (secrets never live in wrangler.jsonc/the repo):
  //   wrangler secret put R2_ACCESS_KEY_ID       # the R2 API token's Access Key ID
  //   wrangler secret put R2_SECRET_ACCESS_KEY   # the R2 API token's Secret Access Key
  // The token must be Object Read & Write, scoped to the single `deltos-blobs` bucket (least privilege). Also
  // one-time: set the bucket CORS policy (PUT, app origin, x-amz-checksum-sha256 header) — see §5.2.
  // Same-origin PWA hosting: serve the client build as static assets; SPA-fallback unmatched routes
  // to index.html; run the Worker FIRST only for /api/* + the OAuth discovery docs (RFC 8414/9728) so the
  // API + AS metadata are never shadowed by the shell. Note: /oauth/authorize is deliberately NOT here — it
  // is a CLIENT route (the PWA consent screen), served by the SPA fallback (oauth-provider.md §2b).
  "assets": {
    "directory": "../client/dist",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*", "/.well-known/oauth-authorization-server", "/.well-known/oauth-protected-resource"],
  },
  // Rich-embed unfurl cache (GET /api/unfurl). Not yet wired — add after creating the namespace:
  //   wrangler kv namespace create unfurl-cache   # copy the returned id into the block below
  // "kv_namespaces": [
  //   { "binding": "UNFURL_CACHE", "id": "<paste-id-here>" },
  // ],
  //
  // R2 — the content-addressed blob store (plugin-support §7, A4 #126; `blob` host capability via
  // /api/plugin/blob). PRIVATE bucket; all access goes through the authenticated Worker. Provision once:
  //   wrangler r2 bucket create deltos-blobs
  "r2_buckets": [
    { "binding": "BLOBS", "bucket_name": "deltos-blobs" },
  ],
  // Coarse per-principal request-RATE ceiling for the authenticated surface (ROAD-0005 P4, Tier 1). The
  // native Workers rate-limit binding — in-memory, per-colo, NO D1 write — checked at the REST/sync
  // chokepoint (guard()) and the MCP dispatcher, keyed by principal. 200 req / 10s ≈ 1200/min per
  // principal per colo: generous vs. legit sync (~30/min) but stops a runaway/abusive client. period
  // must be 10 or 60 (binding constraint). NOT the cost cap — that's the durable D1 usageCounter (Tier 2).
  "ratelimits": [
    {
      "name": "API_RATE_LIMITER",
      "namespace_id": "2001",
      "simple": { "limit": 200, "period": 10 },
    },
  ],
  // Scheduled retention prune (ROAD-0005 P4, Tier 3) — index.ts `scheduled()` reaps the D1 mirrors: the
  // user-facing `auditLog` projection (>90d) and the `usageCounter` daily counters (>7d). The append-only
  // AE audit dataset is the forensic truth and is NEVER pruned. Daily at 04:00 UTC (low-traffic).
  "triggers": {
    "crons": ["0 4 * * *"],
  },
  //
  // Reserved per the locked architecture — NOT wired in Phase 0:
  //   - Durable Objects (live collaboration's promote-to-DO seam; the E2EE relay)
}
