{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "deltos",
  // Prod lives in the Blackgate Studio Cloudflare account (user-confirmed 2026-06-16).
  "account_id": "462b5ee1e395c11b8523d6c38de0577a",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-01",
  "observability": {
    "enabled": true,
  },
  // Workers AI (custom-keyboard spec §6 — voice-to-text). Binding `AI` powers POST /api/transcribe
  // (Whisper @cf/openai/whisper-large-v3-turbo); reused later by the advanced-LLM spellcheck add-on.
  // NOTE: Workers AI has no local inference — `wrangler dev` can't run it; use a deploy or
  // `wrangler dev --remote`.
  "ai": {
    "binding": "AI",
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "deltos",
      // Prod D1 in the Blackgate Studio account (created 2026-06-16). Local dev uses miniflare's
      // own SQLite file and ignores this id.
      "database_id": "0892afd3-67a2-410b-8131-6b4fa64269d8",
      "migrations_dir": "migrations",
    },
  ],
  // Workers PAID (user upgrade 2026-06-18): raise the CPU ceiling so full-strength Argon2id
  // (m=19456,t=2,p=1) signup/login/reset no longer trips the free-plan ~10ms cap (CF 1102
  // exceededCpu). Full secSys-load-bearing params stay — Paid funds the cost.
  "limits": {
    "cpu_ms": 30000,
  },
  "vars": {
    // F13 fail-CLOSED tripwire: prod refuses the dev-only unverified principal.
    "ENVIRONMENT": "production",
    // F8/PROP-4: the auth audience bound into every signed payload. MUST equal the served hostname
    // (= WebAuthn RP ID = client location.hostname). CANONICAL domain = the custom domain
    // deltos.blackgate.studio (user switch 2026-06-16); the workers.dev origin's auth now 401s by
    // design (passkeys are RP-bound per domain → enroll fresh on the canonical domain).
    "AUTH_AUDIENCE": "deltos.blackgate.studio",
  },
  // Same-origin PWA hosting: serve the client build as static assets; SPA-fallback unmatched routes
  // to index.html; run the Worker FIRST only for /api/* so the API is never shadowed by the shell.
  "assets": {
    "directory": "../client/dist",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*"],
  },
  // Reserved per the locked architecture — NOT wired in Phase 0:
  //   - Durable Objects (live collaboration's promote-to-DO seam; the E2EE relay)
  //   - R2 (the content-addressed blob store)
}
