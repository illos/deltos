# Production build env (Vite bakes VITE_* into the bundle at build time).
# Turnstile sitekey is PUBLIC (rendered into the page) — safe to commit. The matching
# secret is a Worker secret (TURNSTILE_SECRET), set separately at deploy. Both must be
# present for the anti-abuse gate to engage; with neither, login/signup/reset stay open.
VITE_TURNSTILE_SITEKEY=0x4AAAAAADs4u_Shn2r7HhtW
