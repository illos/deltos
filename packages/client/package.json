{
  "name": "@deltos/client",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "deltos PWA shell — the installable local-first surface host. Phase 0 is an empty-but-real shell.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.app.json --noEmit && tsc -p tsconfig.sw.json --noEmit && vite build",
    "preview": "vite preview --port 4173 --host 127.0.0.1",
    "typecheck": "tsc -p tsconfig.app.json --noEmit && tsc -p tsconfig.sw.json --noEmit && tsc -p tsconfig.node.json --noEmit",
    "test": "vitest run"
  },
