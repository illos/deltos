{
  "name": "@deltos/shared",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "deltos spine schemas + API contract — the frozen substrate every surface and the worker build against.",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
